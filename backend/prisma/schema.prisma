generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String   @id @default(uuid())
  publicId       String   @unique // The ID shared with banks
  encryptedPII   String   // AES-GCM encrypted payload
  piiHash        String   // SHA-256 for integrity and linking to blockchain
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  consents       Consent[]
}

model Consent {
  id           String   @id @default(uuid())
  customerId   String
  partnerId    String
  status       String   @default("GRANTED") // GRANTED, REVOKED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [publicId])
  
  @@unique([customerId, partnerId])
}

model BankUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  bankId       String   // e.g. "BANK_A", "BANK_B"
  role         String   // "VERIFIER", "PARTNER"
}
